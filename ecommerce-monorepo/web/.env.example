# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/yiwu_express_db"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Application Configuration
APP_NAME="YIWU EXPRESS"
APP_URL="http://localhost:3000"
APP_ENV="development"

# Company Information
COMPANY_NAME="YIWU EXPRESS"
COMPANY_ADDRESS="Yiwu International Trade City, Zhejiang, China"
COMPANY_PHONE="+86 579 8555 1234"
COMPANY_EMAIL="info@yiwuexpress.com"
COMPANY_COUNTRY="China"

# Email Configuration (optional)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-email-password"
EMAIL_FROM="YIWU EXPRESS <noreply@yiwuexpress.com>"

# Google Maps API (for tracking)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Third-party Services (optional)
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"