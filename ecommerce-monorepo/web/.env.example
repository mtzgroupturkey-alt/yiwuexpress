# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Server Configuration
PORT=3005
NODE_ENV=development

# Exchange Rate API (for automatic currency updates)
# Get your free API key from: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY="your-api-key-here"

# Cron Job Security (optional - for protecting automatic update endpoint)
CRON_SECRET="your-random-secret-for-cron-jobs"
