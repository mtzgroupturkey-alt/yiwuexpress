# Database
DATABASE_URL="postgresql://user:password@localhost:5432/yiwuexpress?schema=public"

# JWT Authentication (REQUIRED - fail fast if missing)
# CRITICAL: Change this to a secure random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Application
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Email (Future use - not required yet, mark as "future use")
# These will be used for email verification, password reset, etc.
SMTP_HOST="smtp.sendgrid.net"          # Future use
SMTP_PORT="587"                         # Future use
SMTP_USER="apikey"                      # Future use
SMTP_PASSWORD=""                        # Future use
SMTP_FROM="noreply@yiwuexpress.com"     # Future use

# Redis (Production - for rate limiting)
# TODO: Replace in-memory rate limiting with Redis in production
# REDIS_URL="redis://localhost:6379"    # Future use
