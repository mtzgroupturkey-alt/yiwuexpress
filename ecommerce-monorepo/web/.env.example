# ============================================
# YIWU EXPRESS - Environment Configuration
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env.local (for local development)
# 2. Copy this file to .env.production (for production server)
# 3. Fill in the appropriate values for each environment
# 4. NEVER commit .env files to Git!
#
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# LOCAL DEVELOPMENT:
# DATABASE_URL="postgresql://postgres:balkhi123@localhost:5432/ecommerce"

# PRODUCTION (dromkok.com):
# DATABASE_URL="postgresql://ecommerce:LzZH5p5SnRtNKfMy@localhost:5432/ecommerce"

DATABASE_URL="postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/ecommerce"

# ============================================
# JWT AUTHENTICATION
# ============================================

# Generate a secure random string (64+ characters)
# Run this to generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET="change_this_to_a_very_long_random_string_at_least_64_characters_long"
JWT_EXPIRES_IN="7d"

# ============================================
# SERVER CONFIGURATION
# ============================================

NODE_ENV="development"
PORT=3001
HOSTNAME="localhost"

# ============================================
# DOMAIN & CORS
# ============================================

# LOCAL:
# NEXT_PUBLIC_API_URL=http://localhost:3001
# ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# PRODUCTION:
# NEXT_PUBLIC_API_URL=https://dromkok.com
# ALLOWED_ORIGINS=https://dromkok.com,https://www.dromkok.com

NEXT_PUBLIC_API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# PAYMENT GATEWAYS (Optional)asdfasd
# ============================================

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# PayPal
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx

# ============================================
# FILE UPLOAD (Optional)
# ============================================

MAX_FILE_SIZE=10485760
UPLOAD_DIR=public/uploads
